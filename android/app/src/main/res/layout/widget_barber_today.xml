<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/barber_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RESUMEN DE HOY"
        android:textColor="#73FFFFFF"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/barber_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/barber_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8CFFFFFF"
        android:textSize="12.5sp"
        android:layout_marginTop="3dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/barber_walkin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+  Registrar walk-in"
        android:gravity="center"
        android:textColor="#111111"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/widget_button_cream"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:layout_marginTop="14dp" />
</LinearLayout>
