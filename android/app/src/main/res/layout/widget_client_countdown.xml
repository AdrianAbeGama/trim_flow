<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/client_b_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRÓXIMA CITA"
        android:textColor="#C9A24B"
        android:textSize="10sp"
        android:letterSpacing="0.14"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/client_b_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/client_b_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8CFFFFFF"
        android:textSize="12.5sp"
        android:layout_marginTop="3dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/client_b_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_pill_gold"
        android:textColor="#C9A24B"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingLeft="11dp"
        android:paddingRight="11dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_marginTop="13dp" />

    <Chronometer
        android:id="@+id/client_b_chrono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_pill_gold"
        android:textColor="#EF9F27"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingLeft="11dp"
        android:paddingRight="11dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_marginTop="13dp"
        android:visibility="gone" />
</LinearLayout>
